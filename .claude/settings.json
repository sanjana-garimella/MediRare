{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(python3 nlp/*:*)",
      "Bash(python3 scripts/*:*)",
      "Bash(python3 schemas/*:*)",
      "Bash(python3 integration/*:*)",
      "Bash(python3 -m pytest*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git pull)",
      "Bash(git add*)",
      "Bash(find . *)",
      "Bash(ls*)",
      "Bash(wc -l *)",
      "Bash(grep *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gate_git_push.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && jq -c . >> .claude/logs/denied.jsonl 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && uvx code-review-graph update --skip-flows --repo \"/Users/sanjana/Downloads/medirare/MediRare\" || true",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && uvx code-review-graph status --repo \"/Users/sanjana/Downloads/medirare/MediRare\" || echo 'Not a git repo, skipping'",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "skillOverrides": {
    "superpowers:using-superpowers": "user-invocable-only"
  }
}
